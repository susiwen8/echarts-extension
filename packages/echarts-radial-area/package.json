{
  "name": "@echarts-extension/radial-area",
  "version": "0.1.0",
  "description": "ECharts extension chart for radial area and radial range-area time series",
  "type": "module",
  "main": "lib/index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "test": "npm run build:ts && vitest run --config ../../vitest.config.js packages/echarts-radial-area/test/radial-area.test.ts",
    "test:unit": "vitest run --config ../../vitest.config.js packages/echarts-radial-area/test/radial-area.test.ts",
    "build": "vite build --config ../../vite.config.js --mode development",
    "release": "vite build --config ../../vite.config.js --mode production && vite build --config ../../vite.config.js --mode development"
  },
  "dependencies": {
    "@echarts-extension/layout-core": "0.1.0"
  },
  "peerDependencies": {
    "echarts": "^5.0.1 || ^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
